{
  "name": "ats",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev worker:embeddings worker:summary worker:evaluation",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "typecheck": "turbo run check-types",
    "seed": "pnpm --filter api prisma:seed",
    "seed:embeddings": "pnpm --filter fastapi seed:embeddings",
    "seed:trigger": "pnpm --filter api trigger:evaluations"
  },
  "devDependencies": {
    "prettier": "3.7.4",
    "turbo": "2.8.9",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=18"
  }
}