# Redis queue used by BullMQ worker
REDIS_URL="redis://localhost:6379"

# Supabase Postgres direct connection string (or any PostgreSQL URL with pgvector)
# Example: postgresql://postgres.<project-ref>:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB"

# Gemini API key for embeddings
GEMINI_API_KEY="your-gemini-api-key"

# Gemini embedding model
GEMINI_EMBEDDING_MODEL="gemini-embedding-001"

# Gemini API key for LLM (company values suggestions)
GEMINI_LLM_API_KEY="your-gemini-llm-api-key"

# Gemini model for LLM suggestions
GEMINI_LLM_MODEL="gemini-2.5-flash"

# Behavioral questions used by profile suggestions and application feedback
behavioral_question_1="Cuentame sobre una ocasion en la que tuviste que lidiar con un conflicto en un equipo. Cual fue la situacion, como la manejaste y cual fue el resultado?"
behavioral_question_2="Describe una situacion en la que fallaste o cometiste un error importante. Como reaccionaste y que aprendiste de esa experiencia?"

# Batch / collector behavior
EMBEDDING_BATCH_SIZE="50"
EMBEDDING_BATCH_WAIT_SECONDS="2.0"
EMBEDDING_WORKER_CONCURRENCY="50"

# Default Gemini task type for embeddings
EMBEDDING_TASK_TYPE="SEMANTIC_SIMILARITY"

# Gemini output embedding size
EMBEDDING_OUTPUT_DIMENSIONALITY="1536"

# Evaluation scoring thresholds and mandatory blend
SIMILARITY_THRESHOLD="0.65"
IS_MANDATORY_RECALL="0.95"
IS_MANDATORY_WEIGHT="0.5"
CULTURE_PREFERENCE_WEIGHT="0.5"
CULTURE_VALUE_WEIGHT="0.5"

# Supabase
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="ats-files"