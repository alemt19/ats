DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?schema=public"

DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DB"

NODE_ENV="development"
PORT="4000"

# Supabase
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"
SUPABASE_STORAGE_BUCKET="ats-files"

# Redis (BullMQ)
REDIS_URL="redis://localhost:6379"

# Better-Auth
BETTER_AUTH_SECRET="change-me"
BETTER_AUTH_BASE_URL="http://localhost:4000/api/auth"

# Frontend URL for verification/reset links
APP_URL="http://localhost:3000"

# Login soft lock (requires REDIS_URL)
AUTH_LOGIN_MAX_ATTEMPTS="5"
AUTH_LOGIN_ATTEMPT_WINDOW_SECONDS="600"
AUTH_LOGIN_LOCK_SECONDS="900"

# SMTP (Nodemailer)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="no-reply@example.com"

# Notifications
CANDIDATE_STALE_APPLICATION_DAYS="14"
ADMIN_STALE_JOB_DAYS="14"
NOTIFICATIONS_CRON="0 8 * * *"
